# Copy from .env.local on the Vercel dashboard
# https://nextjs.org/learn/dashboard-app/setting-up-your-database#create-a-postgres-database
POSTGRES_USER=looirobot
POSTGRES_PASSWORD=looirobot
POSTGRES_HOST=localhost
POSTGRES_DATABASE=looirobot_app
POSTGRES_URL=postgresql://looirobot:looirobot@localhost:5433/looirobot_app
POSTGRES_PRISMA_URL=postgresql://looirobot:looirobot@localhost:5433/looirobot_app?schema=public
POSTGRES_URL_NON_POOLING=postgresql://looirobot:looirobot@localhost:5433/looirobot_app

DATABASE_URL="postgresql://looirobot:looirobot@localhost:5433/looirobot_app?schema=public"

# `openssl rand -base64 32`
AUTH_SECRET=your-secret-here
AUTH_URL=http://localhost:3000/api/auth